EntityBlueprint
{
	name "units/ground/egg_granan_ice"

	LuaDesc
	{
		script "lua/units/ground/egg.lua"
		database
		{
			min_scale	float:"1.0"
			max_scale	float:"1.3"
			grow		int:"1"
		}		
	}

	HealthDesc
	{
		max_health 					"10"
		health 						"10"
	}

	MeshDesc
	{
		mesh "meshes/units/ground/anoryxian_egg.mesh"
		material "units/ground/egg_ice"
		flags    	"4"											//this flag set to 4 prevents animation poping when eggs are growing
	}

	TypeDesc
	{
		type "ground_unit|ground_unit_small"
	}

	TeamDesc
	{
		team "enemy"
	}

	PhysicsDesc
 	{
		objects
		{
			PhysicsObjectDesc
			{
				type 				"static"
				group_id 			"ground_unit"
				physics_material 	"default"

				Shapes
				{
					PhysicsBoxShape
					{
						x "2"
						y "2"
						z "2"

						position
						{
							x "0.0"
							y "1"
							z "0.0"
						}
					}
				}
			}
		}
	}

	MinimapItemDesc
	{
		type	"quad"
		color
		{
			x "1"
			y "0"
			z "0"
			w "1"
		}
		size
		{
			x "1"
			y "1"
		}

		visibility 		"radar"
		layer_group		"enemies"
	}

	HighlightComponent
	{
	}

	LootDesc
	{
		explosion_max_power 	"8000"
		explosion_min_power 	"4000"
	}

	DestroyDesc
	{
		DestroyPatterns
		{
			Pair
			{
				value
				{
					explosion_type 			"centered"
					explosion_max_power 	"5000"
					explosion_min_power 	"2500"
					explosion_effect_scale 	"1.0"
					explosion_effect 		"effects/enemies_granan/death_cryo"
					part_prefix 			"meshes/units/ground/anoryxian_egg"
					part_material 			"units/ground/egg_ice"
					part_effect 			"effects/enemies_generic/blood_trail_blue"
					part_physics_material	"gibs_light"					
				}

				key "default"
			}					
		}
		
	}

	EggDesc
	{
		blueprint				"units/ground/granan_ice"
		time_to_hatch			"10"
		unit_state_spawn		"state_not_aggressive" // do not touch
	}
}

