FamilyInfo
{
	name 			"bomogan_ice"
	category 		"fauna"
	specimen 		"specimen_bomogan_ice"
	description 	"monster_description/bomogan_ice"
	specimen_chance "0.1"
	scannable_chance 	"0.2"

	subspecies_vec
	{
		SubSpecies
		{
			name "monster_name/bomogan_ice"
			blueprints
			{
				String     units/ground/bomogan_ice
			}
		}
		SubSpecies
		{
			name "monster_name/bomogan_ice_alpha"
			blueprints
			{
				String     units/ground/bomogan_ice_alpha
			}
		}
		SubSpecies
		{
			name "monster_name/bomogan_ice_ultra"
			blueprints
			{
				String     units/ground/bomogan_ice_ultra
			}
		}
	}
		
	familiarity_levels
	{
		FamiliarityLevel
		{
			level "1"
			display "IMAGE|NAME"
			damage_increase "0"
			samples "0"
		}
		
		FamiliarityLevel
		{
			level "2"
			display "IMAGE|NAME|DESCRIPTION|HEALTH|RARE_DROP" 
			damage_increase "0"
			samples "5"
		}

		FamiliarityLevel
		{
			level "3"
			display "IMAGE|NAME|DESCRIPTION|HEALTH|RARE_DROP|RESISTANCES|VULNERABILITIES" 
			damage_increase "0"
			samples "10"
		}

		FamiliarityLevel
		{
			level "4"
			display "IMAGE|NAME|DESCRIPTION|HEALTH|RARE_DROP|RESISTANCES|VULNERABILITIES|DAMAGE|DROP_INCREASE" 
			damage_increase "2"
			drop_increase	"2"
			samples "20"
		}
	}
}

