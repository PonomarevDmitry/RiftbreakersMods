import * from "materials/scripts/pbr.material"

material props/rocks/ice : pbr/snow
{
	set_texture_alias snow_albedo		materials/textures/ground/snow/snow_windy_01_albedo.dds
	set_texture_alias snow_normal		materials/textures/ground/snow/snow_windy_01_normal.dds
	set_texture_alias snow_packed		materials/textures/ground/snow/snow_windy_01_packed.dds

	technique
	{
		pass
		{
			fragment_program_ref deferred_gbuffer_snow_fp
			{
				param_named      cSnowUvScale        float          0.2
				param_named      cSnowNormalThreshold float         0.6
				param_named      cSnowNormalRange    float          0.22
				param_named      cSnowIntensity      float          1.0
				param_named      cSnowNormalStrength float          1.0
        		param_named      cSnowHeightMin      float          -40.0
        		param_named      cSnowHeightMax      float          -20.0
			}
        }
    }
}

material props/rocks/ice/ice_rock_big_01 : props/rocks/ice
{
	set_texture_alias albedo			materials/textures/props/rocks/volcanic/volcanic_rock_big_01_albedo.dds
	set_texture_alias normal			materials/textures/props/rocks/volcanic/volcanic_rock_big_01_normal.dds
	set_texture_alias packed			materials/textures/props/rocks/volcanic/volcanic_rock_big_01_packed.dds
}

