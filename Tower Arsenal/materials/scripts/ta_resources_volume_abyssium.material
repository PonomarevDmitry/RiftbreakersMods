import * from "materials/scripts/ground_resources.material"
import * from "materials/scripts/pbr.material"
import * from "materials/scripts/resources.material"

material resources/resource_abyssium : water/refract
{
	set_texture_alias wave_normal_1			materials/textures/resources/resource_mud_swamp_01_normal.dds
	set_texture_alias wave_normal_2			materials/textures/resources/resource_mud_swamp_normal.dds
	
	set_texture_alias foam_albedo			materials/textures/resources/resource_abyssium_02_albedo.dds
	set_texture_alias foam_packed			materials/textures/resources/resource_morphium_02_packed.dds
	set_texture_alias foam_normal			materials/textures/resources/resource_morphium_02_normal.dds

	set_texture_alias foam_edge_albedo		materials/textures/resources/foam_metallic_edge_albedo.dds
	set_texture_alias foam_edge_packed		materials/textures/resources/foam_metallic_edge_packed.dds
	set_texture_alias foam_edge_normal		materials/textures/resources/foam_metallic_edge_normal.dds

	set_texture_alias flowmap       		materials/textures/flowmap/mud_01_flowmap.dds
	set_texture_alias noise       			materials/textures/noise_tiled.dds

	technique
	{
		pass
		{
            fragment_program_ref water_refract_fp
            {
		        param_named         cTilingFactor               float          30

        		param_named         cWaveScroll            		float4         -0.007 -0.007 0.007 0.007
		        param_named         cWaveNormalFactor1          float          0.4
		        param_named         cWaveNormalFactor2          float          0.8
		        param_named         cWaveRefractFactor          float          0.04

		        param_named         cFoamScroll              	float4         -0.015 -0.015 0.015 0.015
		        param_named         cFoamFactor                 float          2.2
			    param_named         cFoamTillingFactor          float          1.5
				param_named         cFoamRefractFactor          float          0.25
			    param_named         cFoamFlowPower              float          0.4
			    param_named         cFoamFlowSpeed          	float          3

			    param_named         cFoamEdgeFactor             float          1.0
			    param_named         cFoamEdgePower              float          0.10
        		param_named         cFoamEdgeRefractFactor      float          0.25
			    param_named         cFoamEdgeTillingFactor      float          1.5
			    param_named         cFoamEdgeFlowSpeed          float          3.6

		        param_named         cWaterColor                 float3         0.3 0.0 0.5
		        param_named         cWaterBottomColor           float3         0.3 0.0 0.6
			    param_named 		cWaterShoreColor			float3		   0.39 0.0 0.39
		        param_named         cWaterRoughness             float          0.005
		        param_named         cWaterMetalness             float          0.22
		        param_named         cWaterFadeDepth             float          0.50
		        param_named         cWaterRefractDepth          float          0.6
		        param_named         cWaterDepth                 float          0.45

		        param_named         cFresnelPower               float          0.4
		        param_named         cFresnelScale               float          7
		        param_named         cFresnelBias                float          0.7
            }
		}
	}
}

material resources/resource_abyssium_vein : resources/resource_abyssium
{
	
}
	set_texture_alias albedo_1			materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias normal_1			materials/textures/resources/resource_plasma_normal.dds
	set_texture_alias packed_1			materials/textures/resources/resource_plasma_packed.dds
	set_texture_alias emissive_1		materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias albedo_2			materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias normal_2			materials/textures/resources/resource_plasma_01_normal.dds
	set_texture_alias packed_2			materials/textures/resources/resource_plasma_01_packed.dds
	set_texture_alias emissive_2		materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 1

	glow 1

	technique
	{
		pass
		{
			vertex_program_ref deferred_gbuffer_vp
			{

			}
		}
	}
}


material resources/resource_abyssium_storage : resources/resource_liquid
{
	set_texture_alias albedo_1			materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias normal_1			materials/textures/resources/resource_plasma_normal.dds
	set_texture_alias packed_1			materials/textures/resources/resource_plasma_packed.dds
	set_texture_alias emissive_1		materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias albedo_2			materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias normal_2			materials/textures/resources/resource_plasma_01_normal.dds
	set_texture_alias packed_2			materials/textures/resources/resource_plasma_01_packed.dds
	set_texture_alias emissive_2		materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 1

	glow 1

	technique
	{
		pass
		{
			vertex_program_ref deferred_gbuffer_vp
			{

			}
		}
	}
}

material resources/resource_abyssium_pipe : resources/resource_liquid
{
	set_texture_alias albedo_1			materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias normal_1			materials/textures/resources/resource_plasma_normal.dds
	set_texture_alias packed_1			materials/textures/resources/resource_plasma_packed.dds
	set_texture_alias emissive_1		materials/textures/resources/resource_plasmoid_albedo.dds
	set_texture_alias albedo_2			materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias normal_2			materials/textures/resources/resource_plasma_01_normal.dds
	set_texture_alias packed_2			materials/textures/resources/resource_plasma_01_packed.dds
	set_texture_alias emissive_2		materials/textures/resources/resource_plasmoid_01_albedo.dds
	set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 1

	glow 1

	technique
	{
		pass
		{
			vertex_program_ref deferred_gbuffer_tiled_vp
			{
        		param_named      cTilingFactor  float 1
			}
		}
	}
}

material resources/resource_abyssium_fresnel
{
	render_group 109

	fresnel 1 0.5 0 0
	fresnel_color 8 0 0 0.1

	technique
	{
		pass
		{
			check       on
            comp_func   always_pass
            ref_value   1
            pass_op     replace
            two_sided   on

            scene_blend alpha_blend
            depth_bias -4 -1

            vertex_program_ref forward_object_fresnel_fog_vp
			{
			}

			fragment_program_ref forward_object_fresnel_fog_fp
			{
			}

			texture_unit volumetric_fog
			{
				texture 			materials/textures/black_volume.dds
				texture_type 		3d
				content_type 		shared volumetric_fog
				tex_address_mode 	clamp
				filtering 			bilinear
			}
		}
	}
}

