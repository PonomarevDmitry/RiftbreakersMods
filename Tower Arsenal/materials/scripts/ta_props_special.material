import * from "materials/scripts/pbr.material"

material props/special/great_tree/parasite_bulb_the_abyss: pbr/vegetation_deform_no_alpha
{
	set_texture_alias albedo          materials/textures/props/special/great_tree/parasite_bulb_the_abys_albedo.dds
	set_texture_alias normal          materials/textures/props/special/great_tree/parasite_bulb_normal.dds
	set_texture_alias packed          materials/textures/props/special/great_tree/parasite_bulb_packed.dds

	deform 0.15 0.4
}

material props/special/great_tree/the_abys_evil_spore_dead : pbr/vegetation_deform_no_alpha
{
    set_texture_alias albedo           materials/textures/props/special/great_tree/the_abys_evil_spore_albedo.dds
    set_texture_alias normal           materials/textures/props/special/great_tree/evil_spore_normal.dds
    set_texture_alias packed           materials/textures/props/special/great_tree/evil_spore_packed.dds
    set_texture_alias emissive         materials/textures/props/special/great_tree/the_abys_evil_spore_emissive.dds

    glow 5
    deform 0.3 0.7
}

