material props/special/the_abyss_core_energy_ball : pbr/default
{
	set_texture_alias albedo			materials/textures/props/special/alien_structures/core_wreckage_energy_ball_albedo.dds
	set_texture_alias normal			materials/textures/props/special/alien_structures/core_wreckage_energy_ball_normal.dds
	set_texture_alias packed			materials/textures/props/special/alien_structures/core_wreckage_energy_ball_packed.dds
	//set_texture_alias emissive		materials/textures/props/special/alien_structures/core_wreckage_energy_ball_emissive.dds

	glow 3
	//reflection 1 0

	technique
	{
		pass
		{
			fragment_program_ref deferred_loot_fp
			{
				param_named cFresnelColor 	float4 2 1 3 2 //violet
			}
		}
	}
}

