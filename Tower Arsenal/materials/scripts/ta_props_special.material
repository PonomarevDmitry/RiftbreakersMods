material props/special/the_abyss/anoryxian_boss_ultra_heart : pbr/reflections
{
    set_texture_alias albedo           materials/textures/props/rocks/anoryx_violet/anoryx_violet_big_01_albedo.dds
    set_texture_alias normal           materials/textures/props/rocks/anoryx_violet/anoryx_violet_big_01_normal.dds
    set_texture_alias packed           materials/textures/props/rocks/anoryx_violet/anoryx_violet_big_01_packed.dds
    set_texture_alias emissive         materials/textures/props/rocks/anoryx_violet/anoryx_violet_big_01_emissive.dds
    set_texture_alias subsurface       materials/textures/props/rocks/anoryx_violet/anoryx_violet_big_01_subsurface.dds
    set_texture_alias gradient         materials/textures/gradient/waves.dds 180 3
    //set_texture_alias reflection       materials/textures/skybox/skybox_reflection_violet.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 2
	//reflection 1 0

	technique
	{
		pass
		{
			fragment_program_ref deferred_loot_fp
			{
				param_named cEmissiveColor  float4 0 15 70 1
				param_named cFresnelColor 	float4 2 1 3 2 //violet
				param_named cFresnelBias    float 0.05
				param_named cFresnelScale   float 1
				param_named cFresnelPower   float 2
			}
		}
	}
}

