material props/special/abyss_core_wreckage_barrier_energy
{
    render_group 61

    technique
    {
		pass
		{
			depth_write off
			scene_blend alpha_blend
			cull_hardware none

			vertex_program_ref forward_object_texture_fresnel_fog_world_vp
            {
            }

			fragment_program_ref wall_energy_inverted_fp
			{
				param_named cEmissiveColor  float4 0 25 70 1
				param_named cFresnelColor 	float4 0 1 4 1 //blue
				param_named cFresnelBias    float 0.05
				param_named cFresnelScale   float 1
				param_named cFresnelPower   float 2
			}

            texture_unit diffuse
            {
                texture 		materials/textures/buildings/defense/wall_energy_lvl_1_energy_albedo.dds
                filtering 		anisotropic
            }

            texture_unit emissive
            {
                texture 		materials/textures/noise_tiled.dds
                filtering 		anisotropic
            }

            texture_unit gradient
            {
                anim_texture	materials/textures/gradient/cloudy_gradient.dds 174 3
				filtering 		bilinear
				tex_address_mode wrap
            }

            texture_unit volumetric_fog
			{
				texture 			materials/textures/black_volume.dds
				texture_type 		3d
				content_type 		shared volumetric_fog
				tex_address_mode 	clamp
				filtering 			bilinear
			}
        }
    }
}

material props/special/abyss_core_wreckage_barrier : props/special/abyss_core_wreckage_barrier_energy
{
    set_texture_alias diffuse			materials/textures/props/special/alien_structures/core_wreckage_barrier_albedo.dds
    set_texture_alias emissive			materials/textures/props/special/alien_structures/core_wreckage_barrier_emissive.dds

	glow 6

	technique
	{
		pass
		{
			fragment_program_ref wall_energy_fp
			{
				param_named cEmissiveColor  float4 0 10 80 1
				param_named cFresnelColor 	float4 0 1 4 1 //blue
				param_named cFresnelBias    float 0
				param_named cFresnelScale   float 1
				param_named cFresnelPower   float 0.1
			}
		}
	}
}

