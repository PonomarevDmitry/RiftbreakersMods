	set_texture_alias emissive			materials/textures/props/special/interactive/large_spore_sample_emissive.dds
    set_texture_alias gradient         materials/textures/gradient/waves.dds 180 3

	glow 2

	technique
	{
		pass
		{
			fragment_program_ref deferred_loot_fp
			{
				param_named cFresnelColor 	float4 0 1 3 1 //blue
			}
		}
	}
}

