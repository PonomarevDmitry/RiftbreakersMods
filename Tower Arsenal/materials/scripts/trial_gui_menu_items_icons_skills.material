import * from "materials/scripts/gui.material"

material gui/menu/items_icons/skills/damage_trail_plasmoid : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/items_icons/skills/damage_trail_plasmoid.dds
}

material gui/menu/items_icons/skills/damage_trail_plasmoid_disabled : gui/default_disabled
{
	set_texture_alias diffuse materials/textures/gui/menu/items_icons/skills/damage_trail_plasmoid.dds
}

