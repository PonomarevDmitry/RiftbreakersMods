import * from "materials/scripts/units_base.material"
import * from "materials/scripts/gui.material"

material units/ground/cosmic_gulgor : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_gulgor_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/gulgor_normal.dds
	set_texture_alias packed			materials/textures/units/ground/gulgor_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_gulgor_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 3
}

material gui/menu/species/fauna/cosmic_gulgor : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_gulgor.dds
}

material gui/hud/fauna/cosmic_gulgor_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_gulgor_icon.dds
}

// cosmic_gulgor_alpha

material units/ground/cosmic_gulgor_alpha : 		units/ground/blue_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_gulgor_alpha_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/gulgor_alpha_normal.dds
	set_texture_alias packed			materials/textures/units/ground/gulgor_alpha_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_gulgor_alpha_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 5

	glow 3
}

material gui/menu/species/fauna/cosmic_gulgor_alpha : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_gulgor_alpha.dds
}

material gui/hud/fauna/cosmic_gulgor_alpha_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_gulgor_alpha_icon.dds
}

// cosmic_gulgor_ultra

material units/ground/cosmic_gulgor_ultra : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_gulgor_ultra_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/gulgor_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/gulgor_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_gulgor_ultra_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 5

	glow 6
}

material gui/menu/species/fauna/cosmic_gulgor_ultra : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_gulgor_ultra.dds
}

material gui/hud/fauna/cosmic_gulgor_ultra_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_gulgor_ultra_icon.dds
}

material units/ground/cosmic_gulgor_boss : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_gulgor_boss_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/gulgor_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/gulgor_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_gulgor_boss_emissive.dds
	set_texture_alias reflection       	materials/textures/skybox/skybox_reflection.dds

	glow 2
	reflection 1 25
}

material gui/menu/species/fauna/cosmic_gulgor_boss : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_gulgor_boss.dds
}

material gui/hud/fauna/cosmic_gulgor_boss_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_gulgor_boss_icon.dds
}

material units/ground/cosmic_gulgor_crystal : pbr/reflections_alpha_test
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_gulgor_crystal_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/gulgor_crystal_normal.dds
	set_texture_alias packed			materials/textures/units/ground/gulgor_crystal_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_gulgor_crystal_emissive.dds
	set_texture_alias reflection       	materials/textures/skybox/skybox_reflection.dds

	glow 2
	reflection 1 25
}
