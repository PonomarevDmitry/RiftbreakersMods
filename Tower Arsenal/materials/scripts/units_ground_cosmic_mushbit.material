import * from "materials/scripts/units_base.material"
import * from "materials/scripts/gui.material"

material units/ground/cosmic_mushbit : units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_mushbit_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/mushbit_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/mushbit_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_mushbit_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 9
}

material gui/menu/species/fauna/cosmic_mushbit : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_mushbit.dds
}

material gui/hud/fauna/cosmic_mushbit_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_mushbit_icon.dds
}

//////////////////////////
//    cosmic_mushbit alpha
//////////////////////////

material units/ground/cosmic_mushbit_alpha : 		units/ground/blue_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_mushbit_alpha_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/mushbit_alpha_normal.dds
	set_texture_alias packed			materials/textures/units/ground/mushbit_alpha_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_mushbit_alpha_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 9
}

material gui/menu/species/fauna/cosmic_mushbit_alpha : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_mushbit_alpha.dds
}

material gui/hud/fauna/cosmic_mushbit_alpha_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_mushbit_alpha_icon.dds
}

//////////////////////////
//    cosmic mushbit ultra
//////////////////////////

material units/ground/cosmic_mushbit_ultra : units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_mushbit_ultra_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/mushbit_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/mushbit_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_mushbit_ultra_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 9
}

material gui/menu/species/fauna/cosmic_mushbit_ultra : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_mushbit_ultra.dds
}

material gui/hud/fauna/cosmic_mushbit_ultra_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_mushbit_ultra_icon.dds
}
