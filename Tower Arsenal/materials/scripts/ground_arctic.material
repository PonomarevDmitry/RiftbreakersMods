import * from "materials/scripts/pbr.material"
//== ARCTIC TEXTURES ==\\

material ground/arctic/arctic_ground : pbr/default
{
	terrain_type 	 "arctic"
	set_texture_alias albedo 	materials/textures/ground/arctic/arctic_ground_albedo.dds
	set_texture_alias normal 	materials/textures/ground/acid/acid_ground_25_normal.dds
	set_texture_alias packed 	materials/textures/ground/acid/acid_ground_25_packed.dds
	set_texture_alias emissive 	materials/textures/ground/arctic/arctic_ground_emissive.dds
	set_texture_alias gradient 	materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 6.5
}

material ground/arctic/arctic_rough_01 : pbr/default
{
	terrain_type 	 "arctic"
	set_texture_alias albedo materials/textures/ground/arctic/arctic_rough_01_albedo.dds
	set_texture_alias normal materials/textures/ground/snow/snow_rough_01_normal.dds
	set_texture_alias packed materials/textures/ground/snow/snow_rough_01_packed.dds
}

