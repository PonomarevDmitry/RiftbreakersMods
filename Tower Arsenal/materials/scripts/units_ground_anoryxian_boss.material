import * from "materials/scripts/units_base.material"

///--------- Anoryxian Boss Ultra -----------//
///////////////////////////////////////////////

material units/ground/anoryxian_boss_ultra_01 : units/ground/red_blood_reflections
{
	set_texture_alias albedo			materials/textures/units/ground/anoryxian_boss_ultra_01_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/anoryxian_boss_alpha_01_normal.dds
	set_texture_alias packed			materials/textures/units/ground/anoryxian_boss_alpha_01_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/anoryxian_boss_ultra_01_emissive.dds
//	set_texture_alias reflection        materials/textures/skybox/skybox_reflection_violet.dds



	glow 10
	reflection 0.35 13
}

material units/ground/anoryxian_boss_ultra_02 : units/ground/red_blood_reflections
