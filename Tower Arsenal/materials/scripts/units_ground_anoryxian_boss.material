	set_texture_alias packed			materials/textures/units/ground/anoryxian_boss_alpha_02_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/anoryxian_boss_ultra_02_emissive.dds
//	set_texture_alias reflection        materials/textures/skybox/skybox_reflection_violet.dds

	glow 10
	reflection 0.35 10
}

