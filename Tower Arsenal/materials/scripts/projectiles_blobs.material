import * from "materials/scripts/pbr.material"

material projectiles/blob_cosmic : pbr/vegetation_deform
{
	set_texture_alias albedo		materials/textures/projectiles/blob_cosmic_albedo.dds
	set_texture_alias normal		materials/textures/projectiles/blob_acid_normal.dds
	set_texture_alias packed		materials/textures/projectiles/blob_acid_packed.dds
	set_texture_alias emissive		materials/textures/projectiles/blob_cosmic_emissive.dds

	glow 4
	deform 0.4 2.5
}

material projectiles/blob_plasmoid : pbr/vegetation_deform
{
	set_texture_alias albedo		materials/textures/projectiles/blob_plasmoid_albedo.dds
	set_texture_alias normal		materials/textures/projectiles/blob_acid_normal.dds
	set_texture_alias packed		materials/textures/projectiles/blob_acid_packed.dds
	set_texture_alias emissive		materials/textures/projectiles/blob_plasmoid_emissive.dds

	glow 2
	deform 0.4 2.5
}
