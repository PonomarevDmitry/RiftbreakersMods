import * from "materials/scripts/buildings_base.material"

material buildings/defense/tower_drone_attack_acidic_lvl_1 : buildings/destructible
{
	set_texture_alias albedo			materials/textures/buildings/defense/tower_drone_attack_acidic_lvl_1_albedo.dds
