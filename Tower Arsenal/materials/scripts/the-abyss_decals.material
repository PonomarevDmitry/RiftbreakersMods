import * from "materials/scripts/decal.material"

material decals/the-abyss_decal : decal/default
{
	set_texture_alias albedo materials/textures/decals/the-abyss_decal_albedo.dds
	set_texture_alias normal materials/textures/decals/spawner_canceroth_decal_normal.dds
	set_texture_alias packed materials/textures/decals/spawner_canceroth_decal_packed.dds
}

