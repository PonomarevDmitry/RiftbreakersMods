import * from "materials/scripts/units_base.material"
import * from "materials/scripts/gui.material"

material units/ground/cosmic_crawlog : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_crawlog_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/crawlog_normal.dds
	set_texture_alias packed			materials/textures/units/ground/crawlog_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_crawlog_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 6
}

// cosmic_crawlog_resurrected

material units/ground/cosmic_crawlog_resurrected : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_crawlog_resurrected_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/crawlog_normal.dds
	set_texture_alias packed			materials/textures/units/ground/crawlog_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_crawlog_resurrected_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 5

	glow 8
}

material gui/menu/species/fauna/cosmic_crawlog : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_crawlog.dds
}

material gui/hud/fauna/cosmic_crawlog_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_crawlog_icon.dds
}

// cosmic_crawlog_alpha

material units/ground/cosmic_crawlog_alpha : 		units/ground/blue_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_crawlog_alpha_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/crawlog_alpha_normal.dds
	set_texture_alias packed			materials/textures/units/ground/crawlog_alpha_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_crawlog_alpha_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 5

	glow 6
}

material gui/menu/species/fauna/cosmic_crawlog_alpha : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_crawlog_alpha.dds
}

material gui/hud/fauna/cosmic_crawlog_alpha_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_crawlog_alpha_icon.dds
}

// cosmic_crawlog_ultra

material units/ground/cosmic_crawlog_ultra : 		units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_crawlog_ultra_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/crawlog_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/crawlog_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_crawlog_ultra_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 174 5

	glow 8
}

material gui/menu/species/fauna/cosmic_crawlog_ultra : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_crawlog_ultra.dds
