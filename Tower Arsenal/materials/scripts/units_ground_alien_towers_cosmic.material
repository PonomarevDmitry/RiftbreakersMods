import * from "materials/scripts/units_base.material"

//-------------------------------------ALIEN_TOWERS COSMO-------------------------------------\\

material units/ground/alien_tower_artillery_cosmo : pbr/default
{
	set_texture_alias albedo			materials/textures/units/ground/alien_tower_artillery_cosmo_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/alien_tower_artillery_normal.dds
	set_texture_alias packed			materials/textures/units/ground/alien_tower_artillery_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/alien_tower_artillery_cosmo_emissive.dds

	glow 3

}

//-------------------------------------ALIEN_TOWERS MKII-------------------------------------\\

material units/ground/alien_tower_artillery_cosmo_mkII : pbr/default
{
	set_texture_alias albedo			materials/textures/units/ground/alien_tower_artillery_cosmo_mkII_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/alien_tower_plasma_normal.dds
	set_texture_alias packed			materials/textures/units/ground/alien_tower_plasma_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/alien_tower_artillery_cosmo_mkII_emissive.dds

	glow 2

}

