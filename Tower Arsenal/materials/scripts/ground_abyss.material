import * from "materials/scripts/pbr.material"

material ground/abyss/abyss_ground_01 : pbr/default
{
	//terrain_type 	 "default"

	set_texture_alias albedo materials/textures/ground/abyss/abyss_ground_01_albedo.dds
	set_texture_alias normal materials/textures/ground/swamp/organic_ground_01_normal.dds
	set_texture_alias packed materials/textures/ground/swamp/organic_ground_01_packed.dds
}

material ground/abyss/abyss_ground_02 : pbr/default
{
	terrain_type 	 "default"

	set_texture_alias albedo materials/textures/ground/abyss/abyss_ground_02_albedo.dds
	set_texture_alias normal materials/textures/ground/swamp/organic_ground_01_normal.dds
	set_texture_alias packed materials/textures/ground/swamp/organic_ground_01_packed.dds
}

material ground/abyss/abyss_ground_03 : pbr/default
{
	terrain_type 	 "default"

	set_texture_alias albedo materials/textures/ground/abyss/abyss_ground_03_albedo.dds
	set_texture_alias normal materials/textures/ground/swamp/organic_ground_01_normal.dds
	set_texture_alias packed materials/textures/ground/swamp/organic_ground_01_packed.dds
}

material ground/abyss/abyss_ground_04 : pbr/default
{
	terrain_type 	 "default"

	set_texture_alias albedo materials/textures/ground/abyss/abyss_ground_04_albedo.dds
	set_texture_alias normal materials/textures/ground/swamp/organic_ground_01_normal.dds
	set_texture_alias packed materials/textures/ground/swamp/organic_ground_01_packed.dds
}

material ground/abyss/quicksand : pbr/default
{
	terrain_type 	 "abyss-pit"

	set_texture_alias normal materials/textures/ground/desert/small_dunes_01_normal.dds
	set_texture_alias albedo materials/textures/ground/abyss/small_abysspit_01_albedo.dds
	set_texture_alias packed materials/textures/ground/desert/small_dunes_01_packed.dds
}

