import * from "materials/scripts/gui.material"

material gui/menu/biomes_prev/ArcticIslands : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/ArcticIslands.dds
}

material gui/menu/biomes_prev/ArcticIslands_base : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/ArcticIslands_base.dds
}

material gui/menu/biomes_prev/the_abys : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/the_abys.dds
}

material gui/menu/biomes_prev/the_abys_base : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/the_abys_base.dds
}

material gui/menu/biomes_prev/the_abys_lakes : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/the_abys_lakes.dds
}

material gui/menu/biomes_prev/the_abys_lakes_base : gui/default

{
	set_texture_alias diffuse			materials/textures/gui/menu/biomes_prev/the_abys_lakes_base.dds
}

