//  Mushrooms Cryogenic  // cosmic_yeast //

material props/mushrooms/cosmic_yeast : pbr/vegetation_deform_no_alpha
{
	set_texture_alias albedo     materials/textures/props/mushrooms/bulb_cryogenic_albedo.dds
	set_texture_alias normal     materials/textures/props/mushrooms/bulb_acid_skin3_normal.dds
	set_texture_alias packed     materials/textures/props/mushrooms/bulb_acid_skin3_packed.dds
	set_texture_alias emissive   materials/textures/props/mushrooms/bulb_cryogenic_emissive.dds
	set_texture_alias gradient   materials/textures/gradient/cloudy_gradient.dds 168 8

	glow 2.0
	deform 0.15 1
	subsurface 0.5 0 1.5 0
}

material props/mushrooms/cosmic_yeast_parts : pbr/vegetation_no_alpha
{
	set_texture_alias albedo     materials/textures/props/mushrooms/bulb_cryogenic_albedo.dds
