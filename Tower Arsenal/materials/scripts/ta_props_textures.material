	set_texture_alias albedo 	materials/textures/props/trees/wyginus_big_02_skin4_albedo.dds
	set_texture_alias normal 	materials/textures/props/trees/wyginus_big_02_skin2_normal.dds
	set_texture_alias packed 	materials/textures/props/trees/wyginus_big_02_skin2_packed.dds
	set_texture_alias emissive materials/textures/props/trees/wyginus_big_02_skin4_emissive.dds

	glow 10
}

