import * from "materials/scripts/pbr.material"
//  Grass Standard Blue  //

material props/grass/arctic_blue_set : pbr/vegetation
{
	set_texture_alias albedo 	materials/textures/props/grass/arctic_blue_albedo.dds
	set_texture_alias normal 	materials/textures/props/grass/standard_blue_normal.dds
	set_texture_alias packed 	materials/textures/props/grass/standard_blue_packed.dds
	set_texture_alias emissive 	materials/textures/props/grass/arctic_blue_emissive.dds

	glow 2.5

	subsurface  0.6 0.8 0 0
}

material props/grass/arctic_blue_skin1 : pbr/vegetation
{
	set_texture_alias albedo 	materials/textures/props/grass/arctic_blue_skin1_albedo.dds
	set_texture_alias normal 	materials/textures/props/grass/standard_skin1_normal.dds
	set_texture_alias packed 	materials/textures/props/grass/standard_skin1_packed.dds

	subsurface 1 .5 0 0
}

//  Grass Standard Prism  //

material props/grass/standard_prism : pbr/vegetation
{
	set_texture_alias albedo 	materials/textures/props/grass/standard_prism_albedo.dds
	set_texture_alias normal 	materials/textures/props/grass/standard_blue_normal.dds
	set_texture_alias packed 	materials/textures/props/grass/standard_blue_packed.dds
	set_texture_alias emissive 	materials/textures/props/grass/standard_prism_emissive.dds

	glow 2.5

	subsurface  0.6 0.8 0 0
}

//  Standard Medium 01 Skin15  //

material props/bush/standard_medium_01_skin15 : pbr/vegetation_twosided
{
	set_texture_alias albedo materials/textures/props/bush/standard_medium_01_skin15_albedo.dds
	set_texture_alias normal materials/textures/props/bush/standard_medium_01_skin4_normal.dds
	set_texture_alias packed materials/textures/props/bush/standard_medium_01_skin4_packed.dds

}

