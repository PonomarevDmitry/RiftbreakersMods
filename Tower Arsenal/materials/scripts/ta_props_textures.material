	set_texture_alias albedo materials/textures/props/trees/exolian_01_skin1_albedo.dds
	set_texture_alias normal materials/textures/props/trees/drexolian_01_skin1_normal.dds
	set_texture_alias packed materials/textures/props/trees/drexolian_01_skin1_packed.dds
