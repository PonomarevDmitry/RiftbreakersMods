}

//  mushrooms exploding Set skin3  //

material props/mushrooms/exploding_big_skin3 : pbr/vegetation_deform_no_alpha
{
	set_texture_alias albedo materials/textures/props/mushrooms/exploding_big_skin3_albedo.dds
	set_texture_alias normal materials/textures/props/mushrooms/exploding_big_skin1_normal.dds
	set_texture_alias packed materials/textures/props/mushrooms/exploding_big_skin1_packed.dds
	set_texture_alias emissive materials/textures/props/mushrooms/exploding_big_skin3_emissive.dds
