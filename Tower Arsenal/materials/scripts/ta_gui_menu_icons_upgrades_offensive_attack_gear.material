import * from "materials/scripts/gui.material"

//          plasmoid_offensive_equipment            \\

material gui/menu/items_icons/upgrades/plasmoid_offensive_equipment : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/items_icons/upgrades/plasmoid_offensive_equipment.dds
}

material gui/menu/items_icons/upgrades/plasmoid_offensive_equipment_disabled : gui/default_disabled
{
	set_texture_alias diffuse materials/textures/gui/menu/items_icons/upgrades/plasmoid_offensive_equipment.dds
}

