import * from "materials/scripts/units_base.material"
import * from "materials/scripts/gui.material"

material units/ground/cosmic_hedroner : units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_hedroner_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/hedroner_normal.dds
	set_texture_alias packed			materials/textures/units/ground/hedroner_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_hedroner_emissive.dds
	set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 15
}

material gui/menu/species/fauna/cosmic_hedroner : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_hedroner.dds
}

material gui/hud/fauna/cosmic_hedroner_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_hedroner_icon.dds
}

// cosmic_hedroner_alpha

material units/ground/cosmic_hedroner_alpha : 		units/ground/blue_blood
{
	set_texture_alias albedo			materials/textures/units/ground/cosmic_hedroner_alpha_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/hedroner_alpha_normal.dds
	set_texture_alias packed			materials/textures/units/ground/hedroner_alpha_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_hedroner_alpha_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 7
}

material gui/menu/species/fauna/cosmic_hedroner_alpha : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/cosmic_hedroner_alpha.dds
}

material gui/hud/fauna/cosmic_hedroner_alpha_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/cosmic_hedroner_alpha_icon.dds
}

