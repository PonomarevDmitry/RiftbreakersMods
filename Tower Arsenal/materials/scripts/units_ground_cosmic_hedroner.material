	set_texture_alias albedo			materials/textures/units/ground/cosmic_hedroner_ultra_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/hedroner_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/hedroner_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/cosmic_hedroner_ultra_emissive.dds
	set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

