// hedroner_arctic

material units/ground/hedroner_arctic : units/ground/base_flowfield
{
	set_texture_alias albedo			materials/textures/units/ground/hedroner_arctic_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/hedroner_morphium_normal.dds
	set_texture_alias packed			materials/textures/units/ground/hedroner_morphium_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/hedroner_arctic_emissive.dds

	set_texture_alias albedo_2			materials/textures/units/ground/hedroner_arctic_blood_albedo.dds
	set_texture_alias normal_2			materials/textures/units/ground/black_blood_normal.dds
	set_texture_alias packed_2			materials/textures/units/ground/black_blood_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/hedroner_arctic_blood_emissive.dds

 	set_texture_alias flowmap       	materials/textures/units/ground/hedroner_flow.dds

	glow 3.5

    technique
    {
        pass
        {
			fragment_program_ref deferred_damage_units_flowfield_fp
			{
			    param_named      cFlowPhaseScale         float          2.5
		        param_named      cFlowNoiseTillingFactor float          0.01
		        param_named      cFlowSpeed              float          1.5
		        param_named      cFlowPower              float          0.9
			}
        }
    }
}

material gui/menu/species/fauna/hedroner_arctic : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna/hedroner_arctic.dds
}

material gui/hud/fauna/hedroner_arctic_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna/hedroner_arctic_icon.dds
}

// cosmic_hedroner_boss

