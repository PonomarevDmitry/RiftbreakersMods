import * from "materials/scripts/decal.material"

material decals/effects/blood_splat_cryogenic_glowing_1 : decal/default
{
	set_texture_alias albedo			materials/textures/decals/effects/blood_splat_cryogenic_1_albedo.dds
	set_texture_alias normal			materials/textures/decals/effects/blood_splat_1_normal.dds
	set_texture_alias packed			materials/textures/decals/effects/blood_splat_1_packed.dds
	set_texture_alias emissive			materials/textures/decals/effects/blood_splat_cryogenic_1_albedo.dds
	glow 6
}

