import * from "materials/scripts/pbr.material"
import * from "materials/scripts/gui.material"
import * from "materials/scripts/buildings_base.material"

//----BIOME ENHACEMENT GEN----//
//----------------------------//
material buildings/main/biome_enhacement_generator : buildings/destructible
{
    set_texture_alias albedo            materials/textures/buildings/main/biome_enhacement_generator_albedo.dds
    //set_texture_alias normal            materials/textures/buildings/main/seismic_laboratory_normal.dds
    //set_texture_alias packed            materials/textures/buildings/main/seismic_laboratory_packed.dds
    set_texture_alias emissive          materials/textures/buildings/main/biome_enhacement_generator_emissive.dds
    
    glow 6

}


material buildings/main/biome_enhacement_generator_dissolve : pbr/height_dissolve
{
    set_texture_alias albedo            materials/textures/buildings/main/biome_enhacement_generator_albedo.dds
    //set_texture_alias normal            materials/textures/buildings/main/seismic_laboratory_normal.dds
    //set_texture_alias packed            materials/textures/buildings/main/seismic_laboratory_packed.dds
    set_texture_alias emissive          materials/textures/buildings/main/biome_enhacement_generator_emissive.dds
    
    glow 6
}


material gui/hud/building_icons/biome_enhacement_generator : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator.dds
}

material gui/hud/building_icons/biome_enhacement_generator_disabled : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator_disabled.dds
}

//-BIOME ENHACEMENT GEN LVL2--//
//----------------------------//


material gui/hud/building_icons/biome_enhacement_generator_lvl_2 : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator_lvl_2.dds
}

material gui/hud/building_icons/biome_enhacement_generator_lvl_2_disabled : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator_lvl_2_disabled.dds
}

//-BIOME ENHACEMENT GEN LVL3--//
//----------------------------//


material gui/hud/building_icons/biome_enhacement_generator_lvl_3 : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator_lvl_3.dds
}

material gui/hud/building_icons/biome_enhacement_generator_lvl_3_disabled : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/building_icons/biome_enhacement_generator_lvl_3_disabled.dds
}
