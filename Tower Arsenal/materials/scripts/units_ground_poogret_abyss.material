import * from "materials/scripts/units_base.material"
import * from "materials/scripts/gui.material"

material units/ground/poogret_abyss : units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/poogret_abyss_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/poogret_normal.dds
	set_texture_alias packed			materials/textures/units/ground/poogret_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/poogret_abyss_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 1.5
}

material gui/menu/species/fauna_neutral/poogret_abyss : gui/default
{
	set_texture_alias diffuse materials/textures/gui/menu/species/fauna_neutral/poogret_abyss.dds
}

material gui/hud/fauna_neutral/poogret_abyss_icon : gui/unsharp
{
	set_texture_alias diffuse materials/textures/gui/hud/fauna_neutral/poogret_abyss_icon.dds
}

// poogret_abyss_alpha

material units/ground/poogret_abyss_alpha : units/ground/blue_blood
{
	set_texture_alias albedo			materials/textures/units/ground/poogret_abyss_alpha_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/poogret_alpha_normal.dds
	set_texture_alias packed			materials/textures/units/ground/poogret_alpha_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/poogret_abyss_alpha_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 1.5
}

// poogret_abyss_ultra

material units/ground/poogret_abyss_ultra : units/ground/violet_blood
{
	set_texture_alias albedo			materials/textures/units/ground/poogret_abyss_ultra_albedo.dds
	set_texture_alias normal			materials/textures/units/ground/poogret_ultra_normal.dds
	set_texture_alias packed			materials/textures/units/ground/poogret_ultra_packed.dds
	set_texture_alias emissive			materials/textures/units/ground/poogret_abyss_ultra_emissive.dds
	//set_texture_alias gradient			materials/textures/gradient/cloudy_gradient.dds 168 5

	glow 1.5
}

