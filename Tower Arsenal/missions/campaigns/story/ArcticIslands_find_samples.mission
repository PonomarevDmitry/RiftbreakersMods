MissionDef
{
    script          "lua/missions/campaigns/story/v2/ArcticIslands/ArcticIslands_find_samples.lua"
	localization_id	"gui/menu/planetary_scanner/mission_ArcticIslands_find_samples"
	description		"gui/menu/planetary_scanner/mission_ArcticIslands_find_samples_description"

    biomes          "ArcticIslands"
    map_size		6

	tile_spawn_rules
	{
		// LARGE 2x1 TILES ARE SPAWNED FIRST
		// 2 LARGE TILES ARE GUARANTEED AT THE CENTER
		biomes/ArcticIslands/tiles/arctic_canyons_02_1x2/arctic_canyons_02_1x2.tile//1x2--tile
		{
			min_instances	1
			max_instances	2
			tile_coord
			{	
				//spawns on the corners hopefully
				2,2
				2,3
				3,2
				3,3			
				3,-3
				3,-2
				2,-3
				2,-2		
				-3,-3
				-3,-2
				-2,-3
				-2,-2		
				-3,2
				-3,3
				-2,2
				-2,3		
			}
		}
		biomes/ArcticIslands/tiles/arctic_canyons_01/arctic_canyons_01.tile//1x1--tile
		{
			max_instances	2
		}
		biomes/ArcticIslands/tiles/arctic_canyons_03/arctic_canyons_03.tile//1x1--tile
		{
			random_weight	4.0
		}
		biomes/ArcticIslands/tiles/arctic_canyons_04/arctic_canyons_04.tile//1x1--tile
		{
			random_weight	4.0
		}
		biomes/ArcticIslands/tiles/arctic_canyons_05/arctic_canyons_05.tile//1x1--tile
		{
			random_weight	5.0
		}
		biomes/ArcticIslands/tiles/arctic_canyons_06/arctic_canyons_06.tile//1x1--tile
		{
			random_weight	6.0
		}
		biomes/ArcticIslands/tiles/arctic_lakes_03/arctic_lakes_03.tile//?x?--tile
		{
			max_instances	1
			tile_coord
			{	
				//spawns in the middle hopefully
				0,1
				0,0		
				0,-1
			}
		}
		biomes/ArcticIslands/tiles/arctic_lakes_01/arctic_lakes_01.tile//1x1--tile-acid-liquid
		{
			max_instances	3
			tile_coord
			{	
				//spawns in the middle hopefully
				0,1
				0,0		
				0,-1
			}
