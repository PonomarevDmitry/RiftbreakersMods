	mission_object_spawners
	{		
        GridSpawner
        {
            spawn_pool                  "yeast_root"
	        spawn_team                  "enemy"
			spawn_min_free_cell_margin	5

			spawn_minmax_distance_from_edge 550

            spawn_min_distance_from_pools
            {
                player_spawn_point      250
                loot_containers         50				
                underground_treasures   30
                yeast_root   			100
				resource_volumes		15
            }

            spawn_blueprints
            { 				
                units/ground/cosmic_yeast_root_origin_reserach_mission
                {       
					spawn_entity_name "root"
					spawn_instances_minmax      3,3
					spawn_chance           1
                }
            }
        }
		
		
		//----- DREXOLIAN ARCTIC SPAWN -----		
		
        MarkerBlueprintSpawner
        {
            spawn_pool               "drexolian,arctic"
            spawn_at_marker          "logic/spawn_prefab_marker_drexolian_arctic"

            spawn_min_distance_from_pools
            {
                player_spawn_point  128.0
                loot_containers     5.0
                resource_volumes    2
            }

            spawn_blueprints
            {
                units/ground/drexolian_arctic
                {
                    spawn_culls_entities_around 0
                    spawn_chance           0.5
                }
                props/trees/exolian_big_01_skin1
                {
                    spawn_culls_entities_around 0
                    
                }
            }
        }
		
		//------ DREXOLIAN ARCTIC END ------		
		//											
		//------ TA PLANT TOWERS START -----		
		
        GridSpawner
        {
            spawn_pool                  "plant"
            spawn_team                  "enemy"
            spawn_min_free_cell_margin	3
            spawn_within_destructible_volumes "0"

            spawn_min_distance_from_pools
            {
                player_spawn_point      120
                loot_containers         8
                loot_containers_small   8
                underground_treasures   5
                resource_volumes        5
                plant                   12
                enemy                   5
            }

            spawn_instances_minmax    5,10

            spawn_blueprints
            {                  
                units/ground/cosmic_artigian
                {
                    spawn_instances_minmax      6,9
                    spawn_chance           0.5
                }
                units/ground/cosmic_artigian_alpha
                {
                    spawn_instances_minmax      3,6
                    spawn_chance           0.2
                }
                units/ground/cosmic_artigian_ultra
                {
                    spawn_instances_minmax      1,3
                    spawn_chance           0.1
                }

                logic/position_marker
                {
                    spawn_chance           0.75
                    spawn_culls_entities_around 0
                }
                
            }
        }
		
		//------ TA PLANT TOWERS END -------		
		
		MarkerBlueprintSpawner
        {
            spawn_pool               "loot_containers"

            // find all entities on map with this blueprint as possible spawn point
            spawn_at_marker          "logic/spawn_objective"

            // min distance from objects in other pools
            spawn_min_distance_from_pools
            {
                player_spawn_point  250.0
				mission_objective   100.0
                loot_containers     150.0
				yeast_root   		50
				resource_volumes	10
            }

            // range of spawned blueprints by this pool <min,max>, max can be 0 for unbounded upper limit
            spawn_instances_minmax    15,20

            spawn_blueprints
            {
                spawners/cosmic_spawner_standard
                {
                    // make a roll to check if blueprint can be spawned
                    spawn_chance           0.5
                }

                spawners/cosmic_spawner_advanced
                {
                    spawn_instances_minmax 3,5
                    spawn_chance           0.2
                }

                spawners/cosmic_spawner_superior
                {
                    spawn_instances_minmax 2,3
                    spawn_chance           0.2
                }

                spawners/cosmic_spawner_extreme
                {
                    spawn_instances_minmax 1,2
                    spawn_chance           0.1
                }
            }
        }
		
		GridSpawner
        {
            spawn_pool                  "loot_containers_small"
			spawn_min_free_cell_margin	3

            //terrain_types               "mud,floor"

            spawn_min_distance_from_pools
            {
                yeast_root   			50
				mission_objective   	100
				player_spawn_point      200
                loot_containers         50
                loot_containers_small   120
                underground_treasures   10
				resource_volumes		10
				enemy					5				
            }

            spawn_blueprints
            {
                spawners/loot_container_small_bulb_standard
                {
                    // make a roll to check if blueprint can be spawned
                    spawn_chance           0.25					
                }
                spawners/loot_container_small_bulb_advanced
                {                
                    spawn_chance           0.1
                }				
                spawners/loot_container_small_bulb_superior
                {                 
                    spawn_chance           0.1
                }				
                spawners/loot_container_small_bulb_extreme
                {                 
                    spawn_chance           0.05
                }				
			}
		}
		
		GridSpawner
        {
            spawn_pool                  "power_well"
			spawn_min_free_cell_margin	5

            spawn_min_distance_from_pools
            {
                yeast_root   			50
				player_spawn_point      350
				mission_objective   	100
                loot_containers         50
                loot_containers_small   50
                underground_treasures   10
				resource_volumes		10
				enemy					5
				power_well				450				
            }

            spawn_blueprints
            {
				props/special/power_wells/power_well_source_health
                {                    
                    spawn_chance           0.1					
                }
				props/special/power_wells/power_well_source_forcefield
                {                    
                    spawn_chance           0.1
                }                
				props/special/power_wells/power_well_source_cooldowns
                {
                    spawn_chance           0.1
                }                
				props/special/power_wells/power_well_source_radar
                {                 
                    spawn_chance           0.1
                }
                props/special/power_wells/power_well_source_building
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_loot
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_reflect_damage
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_drones
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_ammo
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_firerate
                {                 
                    spawn_chance           0.1
                }
				props/special/power_wells/power_well_source_damage
                {                 
                    spawn_chance           0.1
                }					
			}
		}

        GridSpawner
        {
            spawn_pool                  "underground_treasures"

            spawn_min_free_cell_margin	3

            spawn_min_distance_from_pools
            {
                yeast_root				50
				player_spawn_point      150
				mission_objective   	100
                loot_containers         50
                loot_containers_small   50
                underground_treasures   100
				resource_volumes		10
				enemy					5
				power_well				15
				yeast_root				20
            }

            spawn_blueprints
            {
                spawners/underground_treasure_spawner
                {
                    spawn_instances_minmax      1,3
                    spawn_discoverable_level    1

                    database
                    {	
                        blueprint 	    string:"items/loot/resources/shard_carbonium_item"
                        min   	 	    int:"100"
                        max   	 	    int:"250"
						package_size    int:"3"
                    }
                }

                spawners/underground_treasure_spawner
                {
                    spawn_instances_minmax      1,3
                    spawn_discoverable_level    1

                    database
                    {	
                        blueprint 	string:"items/loot/resources/shard_steel_item"
                        min   	 	int:"100"
                        max   	 	int:"250"
						package_size    int:"3"
                    }
                }

                spawners/underground_treasure_spawner
                {
                    spawn_instances_minmax      3,5
                    spawn_discoverable_level    1

                    database
                    {	
                        blueprint 	string:"items/loot/resources/shard_plasmanite_item"
                        min   	 	int:"10"
                        max   	 	int:"25"
                    }
                }                
            }
        }
	}

