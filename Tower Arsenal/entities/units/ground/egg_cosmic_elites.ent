EntityBlueprint
{
	name "units/ground/egg_cosmic_canoptrix_elite"

	HealthDesc
	{
		max_health 					"3"
		health 						"3"
	}

	MeshDesc
	{
		mesh      "meshes/units/ground/anoryxian_egg.mesh"
		material  "units/ground/anoryxian_egg"
		flags     	"4" 	//this flag set to 4 prevents animation poping when eggs are growing
	}

	LuaDesc
	{
		script "lua/units/ground/egg.lua"
		database
		{
			min_scale	float:"1.0"
			max_scale	float:"1.25"
			grow_speed	float:"1.0"
			grow		int:"1"
		}
	}

	TypeDesc
	{
		type "ground_unit|ground_unit_small"
	}

	TeamDesc
	{
		team "canoptrix"
	}

	PhysicsDesc
 	{
		objects
		{
			PhysicsObjectDesc
			{
				type 				"static"
				group_id 			"shield"
				physics_material 	"default"

				Shapes
				{
					PhysicsBoxShape
					{
						x "2"
						y "2"
						z "2"

						position
						{
							x "0.0"
							y "1"
							z "0.0"
						}
					}
				}
			}
		}
	}

	MinimapItemDesc
	{
		type	"quad"
		color
		{
			x "1"
			y "0"
			z "0"
			w "1"
		}
		size
		{
			x "1"
			y "1"
		}

		visibility 		"radar"
		layer_group		"enemies"
	}

	HighlightComponent
	{
	}

	DestroyDesc
	{
		DestroyPatterns
		{
			Pair
			{
				value
				{
					explosion_type 			"centered"
					explosion_max_power 	"5000"
					explosion_min_power 	"2500"
					explosion_effect_scale 	"1.0"
					explosion_effect 		"effects/enemies_anoryxian/death_egg"
					part_prefix 			"meshes/units/ground/anoryxian_egg"
					part_material 			"units/ground/anoryxian_egg"
					part_effect 			"effects/enemies_generic/blood_trail_violet"
					part_physics_material	"gibs_light"					
				}
				
				key "default"
			}

		}
	}

}

EntityBlueprint
{
	name 			"units/ground/egg_elite_cosmic_canoptrix"
	base_blueprint 	"units/ground/egg_cosmic_canoptrix_elite"
	
	EggDesc
	{
		blueprint				"units/ground/cosmic_canoptrix_crystal"
		time_to_hatch			"2"
		unit_state_spawn		"state_not_aggressive" // do not touch
	}
}

