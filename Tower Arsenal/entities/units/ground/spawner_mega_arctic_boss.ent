EntityBlueprint
{
	name            "units/ground/spawner_mega_arctic_boss"
	base_blueprint  "units/ground/spawner_cosmic_base"

	DatabaseComponent
	{
		version int:"1"
	}

	MeshDesc
	{
		mesh 		"meshes/units/ground/spawrot.mesh"
		material 	"units/ground/spawner_arctic"
	}	

	UnitsSpawnerDesc
	{
		blueprint				"units/ground/egg_random_boss_01"  //		
		amount_on_single_spawn	"1"   //how many will spawn in 1 spawn so 5 would be normal for the carnoptrix but for bosses i set to 1 change it at your own risk
		max_spawn				"1"   //how many will spawn before attacking its normaly at 100 for the carnooptrix same as above change at your own risk
		time_to_spawn			"60" // 300 is 5 minutes 500 is 8 mins
		unit_state_spawn		"1"   // do not touch
		max_spawn_distance		"40"
		spawn_type				"normal"	//normal|egg
		spawn_marker_bp			"effects/messages_and_markers/objective_marker_violet"
		spawn_marker_life_time	"10"
		can_spawn_when_visible	"1"
		defend_radius			"80"
	}	

	ResistanceComponent
	{
		physical		"0.8"
		fire			"1.1"
		acid			"1.2"
		energy			"1.1"
		cryo			"0.2"
		area			"1.0"
		plasmoid		"1.2"
		cosmic			"1.0"
	}

	DecalDesc
	{
		blueprint "effects/decals/cosmic_crater_01"
		scale
		{
			x		20
			y		20
			z		20
		}
	}

	WeaponItemDesc
	{
	}


	BurstWeaponComponent
	{
		WeaponMuzzles
		{
			WeaponMuzzle
			{
				attachment "att_muzzle"
			}
		}

		WeaponAffector
		{
			emissive_time "0.35"
			emissive_factor "60"
			submesh_idx "1"
		}

		ammo_blueprint 			"units/ground/spawner_arctic_projectile"
		//muzzles_per_fire 			"1"
		muzzle_flash_effect 	"effects/weapons_fluid/cosmic_corrosive_muzzle"

		burst_column_spacing 	"0.8"
		burst_rate 				"0.1"
		burst_column_angle 		"5"
	}	

	TurretDesc
	{
		name   "range"
		target "player|ground_unit|building"
		target_ignore "wall|invisible|ignore_as_target"
		speed "200"
		aim_volume "SphericalAimVolume"
		{
			range_min "0"
			range_max "45"
			aiming_range "50"
		}

		aiming_cooldown "0.1"
		aiming_target_time "0.1"
		aiming_idle_angle "20"
		pitch "be_barrel"
		yaw "be_turret"
		check_target_visibility "1"
		//use_IK "0"
	}
}
EntityBlueprint
{
	name 	"units/ground/spawner_arctic_projectile"

	MeshDesc
	{
		mesh 		"meshes/projectiles/artigian_projectile.mesh"
		material 	"units/ground/cosmic_artigian_alpha"
	}

	EffectDesc
	{
		EffectGroup
		{				
			Effects
			{
				Effect
				{
					blueprint "effects/enemies_cosmic_artigian/artillery_projectile"
				}
			}
		}
	}

	PhysicsDesc
	{
		objects
		{
			PhysicsObjectDesc
			{
				type 				"dynamic"
				group_id 			"grenade"
				physics_material 	"grenade_light"
				Shapes
				{
					PhysicsMeshShape
					{
						mesh "meshes/items/weapons/grenade_50_c1.nxs"
					}
				}
			}
		}
	}

	GrenadeAmmoComponent
	{
		on_enemy_hit_effect 	"effects/cosmic_magmoth_explosion_alpha"
		on_world_hit_effect 	"effects/cosmic_magmoth_explosion_alpha"	
		collision_3d 			"world|world_blocker|world_destructible|destructible|ground_unit|shield"
		collision_2d 			"ground_unit|hitbox|destructible"
		on_world_explosion_delay	 "0"
		on_enemy_explosion_delay	 "0"

		explosion_delay_effect 		"effects/weapons_explosive/weapon_grenade_armed"

		collision_3d 				"world|world_blocker|world_destructible|destructible|ground_unit|building"

		diameter					"1"

		artillery_min_angle 		"25"
		artillery_max_angle 		"45"

		DamagePattern
		{
			area_damage_type		"timed"
			area_damage_duration 	"2.5"
			area_damage_radius		"2"
			time_damage_interval	"0.1"
		}
	}

	children
	{
		EntityBlueprint
		{
			RibbonComponent
			{		
				material 			ribbon/drone_trail_blue_01
				update_bounds 		1
				fade_out_time		0.2
				uv_scroll			"0 -0.5"
				tiling_distance     "4"
				tesselation_step 	"0.25"
				keep_local			"0"

				Ribbons
				{
					Ribbon
					{
						offset "0 0.4 0"
					}

					Ribbon
					{
						offset "0 -0.4 0"
					}
				}
			}
		}
	}
}
