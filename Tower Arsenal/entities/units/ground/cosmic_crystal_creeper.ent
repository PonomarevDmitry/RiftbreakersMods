EntityBlueprint
{
	name  "units/ground/cosmic_crystal_creeper_branch_base"

	HealthDesc
	{ 
		is_manual				"1"
		max_health 				"30"
		health 					"30"
	}

	ResistanceComponent
	{
		//min_damage_threshold 	"5"
		physical		"0.5"
		fire			"1.0"
		acid			"1.0"
		energy			"1.0"
		cryo			"0.5"
		area			"1.0"
		cosmic			"0.5"
		plasmoid		"1.0"
	}

	MeshDesc
	{
		material "props/crystals/cosmic_entvined_01_small_skin3"
		mesh "meshes/props/crystals/entvined_small_01.mesh"
	}

	TypeDesc
	{
		type "ground_unit"
	}

	PhysicsDesc
 	{
		objects
		{
			PhysicsObjectDesc
			{
				type 				"static"
				group_id 			"ground_unit"
				physics_material 	"default"
				Shapes
				{
					PhysicsBoxShape
					{
						x "2"
						y "3"
						z "2"

						position 
						{
							x "0.0"
							y "1"
							z "0.0"
						}
					}
				}
			}
		}
	}

	GridCullerDesc
	{
		Shapes
		{
   			PhysicsBoxShape
   			{
    				x	2
    				y	3
    				z	2
   			}			
		}
	}

	GridMarkerComponent
	{
		mode				"bounds"
		terrain_type  		"cosmic_crystal_creeper_area"	
		extend  			"1"
	}

	MinimapItemDesc
	{
		type	"quad"
		color 
		{
			x "0.5"
			y "0.0"
			z "1.0"
			w "1.0"
		}
		size
		{
			x "1"
			y "1"
		}
		//additional_z_order	"0"
		visibility			"discovered|radar"
		layer_group			"enemies"
	}

	LootDesc
	{
		explosion_max_power 	"8000"
		explosion_min_power 	"4000"
	}

	VegetationComponentDesc
	{
		bending_wind_scale				"0.00"		// ogolne skalowanie sily wiatru						domyslnie: 1.0
		bending_object_scale			"0.00"		// ogolne skalowanie sily odginania obiektow			domyslnie: 1.0
		bending_spring_time				"2.0"		// czas wygaszania
		bending_spring_damping			"30.0"		// wygluszanie oscylacji
		bending_spring_phases			"3.0"		// ilosc oscylacji
		bending_spring_slope_factor		"1.0"		// pseudo "sprezystosc"
		breaking_force_threshold		"10000.0"	// sila po przekroczeniu ktorej, roslina lezy zlamana
		bending_recovery_delay			"15.0"      // czas jaki bedzie lezec po zlamaniu, zanim moze wrocic do punktu 0
		root_mesh 						"meshes/props/crystals/entvined_small_02_root.mesh" // mesh spawnowany po jej zniszczeniu
	}

	EmissiveDayAndNightAffector
	{
		min "0.8"
		max "1.2"

	}

	DestroyDesc
	{
		DestroyPatterns
		{
			Pair
			{
				key "default"
				value
				{
					explosion_type 			"centered"
					explosion_max_power 	"6000"
					explosion_min_power 	"2000"
					explosion_effect 		"effects/destructibles/crystal_big_violet"	
					explosion_effect_scale 	"0.4"
					part_material	 		"props/crystals/entvined_02_set_skin3"
					part_prefix 			"meshes/props/crystals/entvined_small_02"
					//part_effect 			"effects/destructibles/mushroom_part_trail"
				}
			}	
		}		
	}

	EffectDesc
	{
        EffectGroup
        {           
            enabled "1"
            Effects
            {
                Effect
                {
                    blueprint "lights/point/crystal_cosmic_small"
                    offset "0 2 0"
                }
            }
        }	

		EffectGroup
		{
			group 	"time_damage_fire"
			enabled "0"
			Effects
			{
				Effect
				{
					blueprint "effects/destructibles/grass_medium_fire"
					offset "0 1 0"
				}
			}
		}
		EffectGroup
		{
			group 	"spawn"
			enabled "0"
			Effects
			{
				Effect
				{
					blueprint "effects/comsic_crystal_creeper"
					offset "0 0 0"
					scale "0.3 0.4 0.3"
				}
			}
		}		
	}
}

