EntityBlueprint
{
	name  		"units/drones/heavy_drone_player_offensive_plasmoid_blaster"

	ParticleDesc
	{
		name    "rift/plasmoid_drone_projectile"
		scale "1.0 1.0 1.0"
	}

	ProjectileAmmoComponent
	{
		on_enemy_hit_effect 	"effects/player_drone/heavy_drone_projectile_hit_plasmoid"
		on_world_hit_effect 	"effects/player_drone/heavy_drone_projectile_hit_plasmoid"
		on_resisted_hit_effect 	"effects/weapons_generic/projectile_hit_resisted"
		on_shield_hit_effect	"effects/enemies_generic/shield_hit"
		collision_3d 			"world|world_blocker|world_destructible|destructible|ground_unit|hitbox|shield|building|building_small|building_floor"

		friendly_fire				"pass"
	}

	LifeTimeDesc
	{
		time 					0.9
		type 					"camera"
	}
}


