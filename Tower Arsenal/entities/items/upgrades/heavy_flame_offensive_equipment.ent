EntityBlueprint
{
	name "items/upgrades/heavy_flame_offensive_equipment_standard_item"

	InventoryItemDesc
	{
		type 			"upgrade"
		name 			"gui/menu/inventory/upgrade_name/heavy_flame_offensive_equipment_standard"
		icon 			"gui/menu/items_icons/upgrades/flame_offensive_equipment"
		bigger_icon 	"gui/menu/items_icons/upgrades/flame_offensive_equipment"
		description 	"gui/menu/inventory/upgrade_description/heavy_flame_offensive_equipment_description"
	}

	EntityModDesc
	{
	}

	CostDesc
	
	LuaDesc
	{
		script "lua/items/drone_spawner.lua"
		
		database
		{
			drone_blueprint	string:"units/drones/heavy_drone_player_offensive_flame_standard"
			drone_count		int:"1"
		}
	}
	
}

