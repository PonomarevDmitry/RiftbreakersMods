EntityBlueprint
{
	name							"items/skills/damage_trail_plasmoid_item"

	InventoryItemDesc
	{
		type						"skill"
		name						"gui/menu/inventory/skill_name/plasmoid_trial"
		description					"gui/menu/inventory/skill_description/plasmoid_trial"
		icon						"gui/hud/items_icons/skills/damage_trail_plasmoid"
		bigger_icon					"gui/menu/items_icons/skills/damage_trail_plasmoid"
		cooldown					"25"
		rarity						"STANDARD"
		replace_lower_quality		"1"
	}

	LuaDesc
	{
		script "lua/items/skills/damage_trail.lua"		
		
		database
		{
			trail_time 		float:"15"
			trail_spacing 	float:"1"
			trail_effect	string:"effects/projectiles_and_trails/plasmoid_trial"
			stat_bp			string:"effects/projectiles_and_trails/plasmoid_trial"
			trail_extend_time float:"10"
		}
	}

	CostDesc
	{
		is_unique		"1"
	}
}

