{
	name effects/projectiles_and_trails/plasmoid_trial

	base_blueprints
	{
		lights/point/fire_blue_very_small
		effects/no_lifetime
	}

	GridMarkerComponent
	{
		terrain_type	"mech_plasmoid_trail"
		mode 			"1"
		extend  		"3"
	}

	ParticleDesc
	{
		name	"rift/mech_dash_plasmoid"
	}

	SoundDesc
	{
		name "items/skills/dash_acid"
	}

