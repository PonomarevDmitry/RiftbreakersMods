EntityBlueprint
{
	name  "items/weapons/plasmoid_launcher_projectile"

	base_blueprint effects/weapons_explosive/plasmoid_projectile

	MeshDesc
	{
		mesh 		"meshes/projectiles/grenade_shell.mesh"
		material 	"projectiles/plasmoid_launcher"
	}

	PhysicsDesc
	{
		objects
		{
			PhysicsObjectDesc
			{
				type 				"dynamic"
				group_id 			"grenade"
				physics_material 	"grenade_light"
				Shapes
				{
					PhysicsMeshShape
					{
						mesh "meshes/items/weapons/grenade_50_c1.nxs"
					}
				}
			}
		}
	}

	GrenadeAmmoComponent
	{
		on_enemy_hit_effect 		"effects/plasmoid_launcher_explosion_blue"//in effects/plasmoid_minigun
		on_world_hit_effect 		"effects/plasmoid_launcher_explosion_blue"
		on_resisted_hit_effect 		"effects/plasmoid_launcher_explosion_blue"
		hit_effect_direction 		"up"

		on_world_explosion_delay	 "1"
		on_enemy_explosion_delay	 "0"

		explosion_delay_effect 		"effects/ta_weapons_explosive/weapon_grenade_armed"

		collision_3d 				"world|world_blocker|world_destructible|destructible|ground_unit|building"

		diameter					"0.25"

		artillery_min_angle 		"25"
		artillery_max_angle 		"45"

		cluster_count 				"8"
		cluster_max_generation      "0"
		cluster_explosion_radius	"8"
		fly_time_limit 				"0.7"

		DamagePattern
		{
			area_damage_radius	"3"
			area_damage_speed	"30"

			Damages
			{
				Damage
				{
					value 			"5"
					type			"plasmoid"
				}
			}
			TimeDamages
			{
				TimeDamage
				{
					value			"15"
					duration		"5"
					type			"plasmoid"
				}
			}			
		}
	}

	children
	{
		EntityBlueprint
		{
			RibbonComponent
			{		
				material 			ribbon/grenade_trail_blue
				update_bounds 		1
				fade_out_time		0.75
				uv_scroll			"0 -2.5"
				tiling_distance     "0"
				tesselation_step 	"0.25"
				keep_local			"0"

				Ribbons
				{
					Ribbon
					{
						offset "0 0.4 0"
					}

					Ribbon
					{
						offset "0 -0.4 0"
					}
				}
			}
		}
	}
}

