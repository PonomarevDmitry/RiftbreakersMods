EntityBlueprint
{ 
	name "items/weapons/debug_cosmic_minigun"

	MeshDesc
	{
		mesh 		"meshes/items/weapons/minigun.mesh"
		material 	"items/weapons/minigun"
	}
	
 	ShadowExcludeComponent
	{

	}		

	SkeletonDesc
	{
		name "meshes/items/weapons/minigun"
	}

	WeaponMovementDataComponent
	{
		attack_movement_factor	"0.65"
	}

	BurstWeaponComponent
	{
		WeaponAffector
		{
			emissive_time "0.35"
			emissive_factor  "10"
		}		
		WeaponMuzzles
		{
			WeaponMuzzle
			{
				attachment "att_muzzle_1"
			}
		}
		
		ammo_blueprint 				"items/weapons/debug_cosmic_minigun_projectile"

		muzzle_flash_effect 		"effects/cosmic_minigun_muzzle"

		burst_column_spacing 		"0.5"
		burst_rate 					"0.3"
		//burst_column_angle 			"5"
	}

	EffectDesc
	{
		EffectGroup
		{
			group "loot"
			enabled "0"		
			
			Effects
			{
				Effect
				{
					blueprint "effects/loot/mech_lost_weapon_marker"	
					offset "1 0 0"						
				}
			}
		}
		EffectGroup
		{
			group "loot_collect"
			enabled "0"		
			
			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/sniper_rifle_equipped"							
				}
			}
		}
		EffectGroup
		{
			group "item_equipped"
			enabled "0"
			
			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/sniper_rifle_equipped"
				}
			}
		}
		EffectGroup
		{
			group "shooting_empty"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/empty_big_bullet_weapon"
				}
			}
		}
		EffectGroup
		{
			group "shooting"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/minigun_fire_loop"
				}
			}
		}
		EffectGroup
		{
			group "shooting_empty"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/empty_big_bullet_weapon"
				}
			}
		}
		EffectGroup
		{
			group "laser_pointer"
			enabled "1"

			Effects
			{
				Effect
				{
					blueprint "effects/mech/laser_pointer_violet"
					bone "att_muzzle_1"
				}
			}
		}		
	}
}

