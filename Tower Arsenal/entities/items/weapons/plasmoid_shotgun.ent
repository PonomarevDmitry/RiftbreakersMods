///////////////////////////////
EntityBlueprint
{
	name              "items/weapons/plasmoid_shotgun/projectile"
	base_blueprint effects/tower_shotgun/plasmoid_shotgun_bullet

	ProjectileAmmoComponent
	{
		diameter				"1"
		distribution 			"dissipation"
		//dissipation_count 		"10"

		distribution 			"dissipation"
		on_enemy_hit_effect 	"effects/plasma_shotgun_hit_enemy_flesh"//at bottom of the file in effects//
		on_world_hit_effect 	"effects/plasma_shotgun_hit_world_rocks"//--------------------------------//
		on_resisted_hit_effect 	"effects/weapons_generic/projectile_hit_resisted"		
		collision_3d 			"world|world_blocker|world_destructible|destructible|grenade|building|ground_unit|shield"
		collision_2d 			"ground_unit|destructible"
		
		DamagePattern
		{
			area_damage_effect_scale	"splash"
			area_damage_effect	 "effects/weapons_generic/damage_radius_explosion_blue"
		}			
	}
	//LifeTimeDesc
	//{
	//	time 		0.2
	//	type 		"camera"
	//}
}

