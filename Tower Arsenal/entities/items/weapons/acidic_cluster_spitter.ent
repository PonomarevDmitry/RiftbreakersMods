EntityBlueprint
{
	name  "items/weapons/acidic_cluster_spitter"

	MeshDesc
	{
	mesh 		"meshes/items/weapons/spitter.mesh"
	material 	"items/weapons/acidic_cluster_spitter"
	}

	ShadowExcludeComponent
	{

	}		

	SkeletonDesc
	{
		name "meshes/items/weapons/spitter"
	}

	WeaponMovementDataComponent
	{
		attack_movement_factor	"0.65"
	}

	BurstWeaponComponent
	{
		WeaponAffector
		{
			emissive_time "0.35"
			emissive_factor "1.2"
		}
		WeaponMuzzles
		{
			WeaponMuzzle
			{
				attachment "att_muzzle_1"
			}
		}

		ammo_blueprint 				"items/weapons/acidic_projectile"

		muzzles_per_fire 			"1"
		muzzle_flash_effect 		"effects/weapons_fluid/acid_spitter_mod_muzzle"

		burst_column_spacing 		"0.8"
		burst_rate 					"0.08"
		//burst_column_angle 			"0"
	}

	ChargeWeaponComponent
	{
        ChargeLevels
        {
			ChargeLevel
            {
				name 						"charge_level_1"

				charge_failed_effect		"effects/weapons_generic/weapon_charge_failed"
                charging_effect          	"effects/weapons_generic/weapon_charging_lvl1" 
                charged_effect        		"effects/weapons_generic/weapon_charging_maximum"
                charge_fire_effect          "effects/weapons_shotguns/shotgun_fire_charged"
                charge_muzzle_flash_effect  "effects/weapons_shotguns/shotgun_muzzle_flash_charged"
                
                charge_time_start           "0.3"
                charge_time_end             "1"
                charge_muzzle_idx           "0"

                ammo_blueprint 				"items/weapons/acidic_projectile"
				
				burst_rate_factor				"0.5"
				burst_column_spacing_factor		"1"
				burst_column_angle_factor		"1"
            }
        }		
	}

	EffectDesc
	{
		EffectGroup
		{
			group "loot"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/loot/mech_lost_weapon_marker"
					offset "1 0 0"
				}
			}
		}

		EffectGroup
		{
			group "loot_collect"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_bullet/sniper_rifle_equipped"
				}
			}
		}

		 EffectGroup
		{
			group "item_equipped"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_fluid/spitter_equipped"
				}
			}
		}

		EffectGroup
		{
			group "shooting_empty"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/weapons_fluid/empty_fluid_weapon_no_loop"
				}
			}
		}

		EffectGroup
		{
			group "laser_pointer"
			enabled "1"

			Effects
			{
				Effect
				{
					blueprint "effects/mech/laser_pointer_green"
					bone "att_muzzle_1"
				}
			}
		}
	}
}

