EntityBlueprint
{
	name effects/buildings/magma_building_atmosphere

	base_blueprints
	{
		lights/point/fire_violet_very_small
		effects/no_lifetime
	}

	GridMarkerComponent
	{
		mode			"origin"
		terrain_type  	"magma_ground"
		extend  		"2"
	}

	ParticleDesc
	{
		name    "rift/magma_building_ambient"
	}

	DecalDesc
	{	
		blueprint "effects/decals/explosion_hole_big_cosmic_01"
		scale
		{
			x		2.0
			y		2.0
			z		2.0
		
		}
	}

	LifeTimeDesc
	{
		time 		"60"
	}
}

