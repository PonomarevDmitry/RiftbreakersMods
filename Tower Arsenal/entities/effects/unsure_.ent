EntityBlueprint
{
	name "effects/enemies_cosmic/burn_effect"

	LuaDesc
	{
		script "lua/units/skills/hedroner_time_dmg.lua"
		database
		{
			dmg_effect			string:"time_damage_cosmic"
			aura_effect			string:"markers/aura_cosmic"
			dmg_type			string:"cosmic"	
			dmg_per_sec			float:1
			radius				float:5
		}			
	}	
	
	DisplayRadiusComponent
	{
		min_radius_blueprint    	"units/skills/aura_damage_cosmic_area"
		max_radius_blueprint   		"units/skills/aura_damage_cosmic_circle"
	
		max_radius_rotation_speed 	"0"
		min_radius_rotation_speed 	"0"
		fade_out_time 				"5.0"
	}
}

