EntityBlueprint
{
	name effects/tower_shotgun/cryo_shotgun_muzzle_flash

	base_blueprints
	{
		effects/weapons_elemental/muzzle
		lights/point/muzzle_blue_small
		effects/default
	}

	ShockWaveDesc
	{
		power 	"4000"
		speed 	"100"
