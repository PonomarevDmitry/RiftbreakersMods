//mushroom acid bulb purple

EntityBlueprint
{
	name effects/ta_destructibles/acid_bulb_explosion_purple_big

	base_blueprints
	{
		 lights/ta_point/explosion_violet_big
		 effects/default
	}

	GridMarkerComponent
	{
		mode			"bounds"
		terrain_type  	"acid_bulb_cosmic"	
		extend  		"4"
	}

	//BombAmmoComponent
	//{		
	//	DamagePattern
	//	{
	//		area_damage_radius	"8"
	//		area_damage_speed 	"20"
	//
	//		Damages
	//		{
	//			Damage
	//			{
	//				value 			"299"
	//				type			"cosmic"
	//			}
	//		}
	//	}
	//}

	ShockWaveDesc
	{
		power 	"2000"
		speed 	"20"
		radius 	"20"
	}

	ParticleDesc
	{
		name    "rift/acid_bulb_explosion_purple_big"
	}

	CameraShakeDesc
	{
		duration 		"0.8"
		power   		"1"
		falloff_radius 	"40"
		radius   		"60"
		frequency 		"20"
		group			"explosion_big"
	}

	SoundDesc
	{
		name "items/weapons/explosive/explosion_big"
	}

	DecalDesc
	{	
		blueprint "effects/decals/blood_splat_violet_random"
		scale
		{
			x		4.0
			y		4.0
			z		4.0
		}
	}
}

