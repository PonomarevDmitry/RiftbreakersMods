EntityBlueprint 
{
	name "effects/enemies_cosmic_gulgor/projectile"

	base_blueprints
	{
		lights/point/fire_violet_very_small
		effects/no_lifetime
	}

	ParticleDesc
	{
		name    "rift/cosmic_gulgor_projectile"
	}
	SoundDesc
	{
		name 		"enemies/magmoth/muzzle"
	}	

	LuaDesc
	{
		script "lua/units/skills/hedroner_time_dmg.lua"
		database
		{
			dmg_effect			string:"time_damage_cosmic_energy"
			aura_effect			string:"markers/aura_cosmic"
			dmg_type			string:"cosmic_energy"	
			dmg_per_sec			float:1
			radius				float:5.0
		}			
	}	
	
	DisplayRadiusComponent
	{
		min_radius_blueprint    	"units/skills/aura_damage_cosmic_area"
		max_radius_blueprint   		"units/skills/aura_damage_cosmic_circle"
	
		max_radius_rotation_speed 	"0"
		min_radius_rotation_speed 	"0"
		fade_out_time 				"5.0"
	}

}

