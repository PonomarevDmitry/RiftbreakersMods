//-- Acidic Artillery --\\

EntityBlueprint
{
	name effects/tower_acidic_artillery_explosion

	base_blueprints
	{
		lights/point/explosion_green_medium
		effects/default
	}

	ShockWaveDesc
	{
		power 	"2000"
		speed 	"20"
		radius 	"20"
	}

	ParticleDesc
	{
		name    "rift/acidic_artillery_explosion_big"
	}

	CameraShakeDesc
	{
		duration 		"0.2"
		power   		"0.5"
		falloff_radius 	"25"
		radius   		"40"
		frequency 		"20"
		group			"explosion_medium"
	}

	SoundDesc
	{
		name "items/weapons/explosive/explosion_medium"
	}

	DecalDesc
	{	
		blueprint "effects/decals/explosion_hole_random"
		scale
		{
			x		2.5
			y		2.5
			z		2.5
			
		}
	}	
	EffectDesc
	{
		EffectGroup
		{
			group "water_collision"
			enabled "1"				
			
			Effects
			{
				Effect
				{
					blueprint "player/water_collision"
					scale "10 10 10"
				}
			}
		}			
	}		
}

