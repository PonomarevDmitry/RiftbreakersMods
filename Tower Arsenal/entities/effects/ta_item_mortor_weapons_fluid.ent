EntityBlueprint
{
	name effects/weapons_mortars/cosmic_explosion

	base_blueprints
	{
		lights/point/violet_very_small
		effects/default
	}	

	ParticleDesc
	{
		name    "rift/cosmic_explosion_weapon_mortar"
	}

	SoundDesc
	{
		name "items/weapons/explosive/mortar_explosion"
	}

	ShockWaveDesc
	{
		power 	"2000"
		speed 	"20"
		radius 	"20"
	}

	CameraShakeDesc
	{
		duration 		"0.2"
		power   		"0.3"
		falloff_radius 	"25"
		radius   		"40"
		frequency 		"20"
		group			"explosion_medium"
	}

	DecalDesc
	{	
		blueprint "effects/decals/cosmic_crater_01"
		scale
		{
			x		2.5
			y		2.5
			z		2.5
			
		}
	}
}

