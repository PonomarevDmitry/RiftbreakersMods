//-STAIN-DMG-//
///////////////
EntityBlueprint
{
	name effects/enemies_blood_splatter_dmg/glowing_stain


	base_blueprint
	{
		 effects/default
	}					

	GridMarkerComponent
	{
		mode			"bounds"
		terrain_type  	"violet_glowing_stain"	
		extend  		"1"
	}			

	ParticleDesc
	{
		name    "rift/death_violet_very_small"
	}		

	SoundDesc
	{
		name "enemies/generic/enemy_death_small"
	}		

	DecalDesc
	{	
		blueprint "effects/decals/blood_splat_violet_glowing_random"
		scale
		{
			x	1.0
			y	1.0
			z	1.0
		}	
	}		

	LifeTimeDesc
	{
		time 	6
	}

}	
	

