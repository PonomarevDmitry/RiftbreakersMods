//									
//---- YEAST EXPLOSION EFFECT ----\\
//									


EntityBlueprint
{
	name effects/destructibles/cosmic_yeast_explosion_blue_big

	base_blueprints
	{
		 lights/point/explosion_blue_small
		 effects/default
	}

	BombAmmoComponent
	{		
		DamagePattern
		{
			area_damage_radius	"8"
			area_damage_speed 	"20"

			Damages
			{
				Damage
				{
					value 			"99"
					type			"cosmic"
				}
			}
		}
	}

	ShockWaveDesc
	{
		power 	"2000"
		speed 	"20"
		radius 	"20"
	}

	ParticleDesc
	{
		name    "rift/acid_bulb_explosion_blue_big"
	}

	CameraShakeDesc
	{
		duration 		"0.8"
		power   		"1.5"
		falloff_radius 	"40"
		radius   		"60"
		frequency 		"20"
		group			"explosion_big"
	}

	SoundDesc
	{
		name "enemies/generic/enemy_death_big"
	}

	DecalDesc
	{	
		blueprint "effects/decals/blood_splat_blue_random"
		scale
		{
			x		4.0
			y		4.0
			z		4.0
		}
	}
}

