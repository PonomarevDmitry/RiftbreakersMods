EntityBlueprint
{
	name lights/ta_point/explosion_violet_big

	SceneEditorDesc
	{
		mesh 		"meshes/light_point.mesh"
	}

	LightDesc
	{
		type "0"
		scattering_intensity "0.41"
		light_color
		{
			x "0.65"
			y "0.05"
			z "1"
			w "5000.0"
		}

		light_range "20"
		
		light_world_offset
		{
			y "3"
		}		
