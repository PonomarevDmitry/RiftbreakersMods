//---------------------------SHADOW CASTER START---------------------------\\

// boss_fire

EntityBlueprint
{
	name lights/point/ta_boss_shadow_caster_red

	SceneEditorDesc
	{
		mesh 		"meshes/light_point.mesh"
	}

	LightDesc
	{
		type "0"
		scattering_intensity "0.41"
		light_color
		{
			x "1.0"
			y "0.0"
			z "0.0"
			w "100.0" 				// "500"
		}
		light_size 0.1
		is_shadow_caster "1"		// "1"
		light_range "25" 			// "150"
	}

	LightPerlinAffectorComponent
	{
		const_value 	"5"				
		frequency    	"25"
		persistance    	"0.1"
		steps 			"5"
	}

	ShadowComponent
	{
		shadow_intensity "1"
	}
}

