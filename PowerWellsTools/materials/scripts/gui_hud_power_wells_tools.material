import * from "materials/scripts/gui.material"

material gui/hud/tools_icons/power_wells_destroy_tool : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/tools_icons/power_wells_destroy_tool.dds
}

material gui/hud/tools_icons/power_wells_destroy_tool_disabled : gui/default_disabled
{
	set_texture_alias diffuse materials/textures/gui/hud/tools_icons/power_wells_destroy_tool.dds
}



material gui/hud/tools_icons/power_wells_respawn_tool : gui/default
{
	set_texture_alias diffuse materials/textures/gui/hud/tools_icons/power_wells_respawn_tool.dds
}

material gui/hud/tools_icons/power_wells_respawn_tool_disabled : gui/default_disabled
{
	set_texture_alias diffuse materials/textures/gui/hud/tools_icons/power_wells_respawn_tool.dds
}