import * from "materials/scripts/selector.material"

material selector/marker_power_wells_preserve_tool : selector/marker_base
{
	set_texture_alias diffuse			materials/textures/selector/marker_power_wells_preserve_tool.dds
	set_texture_alias emissive			materials/textures/selector/marker_power_wells_preserve_tool_emissive.dds

	technique
	{
		pass
		{
			depth_check			off
			depth_write			off
		}
	}
}



material selector/marker_power_wells_activate_tool : selector/marker_base
{
	set_texture_alias diffuse			materials/textures/selector/marker_power_wells_activate_tool.dds
	set_texture_alias emissive			materials/textures/selector/marker_power_wells_activate_tool_emissive.dds

	technique
	{
		pass
		{
			depth_check			off
			depth_write			off
		}
	}
}